{
  "name": "@helipod/objectstore-substrate",
  "version": "0.1.0",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "LICENSE",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --exclude '**/*.e2e.test.ts' --exclude 'test/gc-driver.test.ts' --exclude 'test/heartbeat-driver.test.ts'",
    "test:e2e": "vitest run test/*.e2e.test.ts test/gc-driver.test.ts test/heartbeat-driver.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@helipod/component": "workspace:*",
    "@helipod/docstore": "workspace:*",
    "@helipod/docstore-sqlite": "workspace:*",
    "@helipod/id-codec": "workspace:*",
    "@helipod/index-key-codec": "workspace:*",
    "@helipod/objectstore": "workspace:*",
    "@helipod/values": "workspace:*"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "catalog:",
    "@helipod/executor": "workspace:*",
    "@helipod/objectstore-fs": "workspace:*",
    "@helipod/objectstore-s3": "workspace:*",
    "@helipod/runtime-embedded": "workspace:*",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helipod-sh/helipod.git",
    "directory": "ee/packages/objectstore-substrate"
  }
}
