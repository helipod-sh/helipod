{
  "name": "@helipod/runtime-cloudflare-shard",
  "version": "0.1.3",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "LICENSE",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --testTimeout=60000 --hookTimeout=60000",
    "test:workers": "vitest run --config vitest.workers.config.ts && vitest run --config vitest.workers.hash.config.ts",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@helipod/runtime-cloudflare": "workspace:*",
    "@helipod/id-codec": "workspace:*",
    "@helipod/index-key-codec": "workspace:*",
    "@helipod/cli": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.5.40",
    "@cloudflare/workers-types": "^4.20241127.0",
    "@helipod/docstore-d1": "workspace:*",
    "@helipod/executor": "workspace:*",
    "@helipod/values": "workspace:*",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helipod-sh/helipod.git",
    "directory": "ee/packages/runtime-cloudflare-shard"
  }
}
