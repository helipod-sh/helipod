{
  "name": "@helipod/fleet",
  "version": "0.1.0",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "LICENSE",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --exclude 'test/fleet-e2e.test.ts'",
    "test:e2e": "vitest run test/fleet-e2e.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "pg": "^8.13.1",
    "@helipod/errors": "workspace:*",
    "@helipod/docstore-postgres": "workspace:*",
    "@helipod/docstore": "workspace:*",
    "@helipod/docstore-sqlite": "workspace:*",
    "@helipod/runtime-embedded": "workspace:*",
    "@helipod/index-key-codec": "workspace:*",
    "@helipod/id-codec": "workspace:*",
    "@helipod/values": "workspace:*"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@helipod/executor": "workspace:*",
    "@helipod/test": "workspace:*",
    "@helipod/scheduler": "workspace:*",
    "@helipod/transactor": "workspace:*",
    "@types/pg": "^8.11.10",
    "@types/node": "catalog:",
    "@types/ws": "^8.5.13",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "ws": "^8.18.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helipod-sh/helipod.git",
    "directory": "ee/packages/fleet"
  }
}
