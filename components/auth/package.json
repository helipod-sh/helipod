{
  "name": "@helipod/auth",
  "version": "0.1.5",
  "license": "FSL-1.1-Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --testTimeout=60000 --hookTimeout=60000"
  },
  "dependencies": {
    "@helipod/component": "workspace:*",
    "@helipod/errors": "workspace:*",
    "@helipod/executor": "workspace:*",
    "@helipod/values": "workspace:*",
    "@simplewebauthn/server": "13.3.2",
    "hash-wasm": "^4.12.0",
    "jose": "6.2.3",
    "oauth4webapi": "3.8.6"
  },
  "devDependencies": {
    "@helipod/docstore-sqlite": "workspace:*",
    "@helipod/runtime-embedded": "workspace:*",
    "@helipod/test": "workspace:*",
    "@levischuck/tiny-cbor": "0.2.11",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helipod-sh/helipod.git",
    "directory": "components/auth"
  },
  "homepage": "https://github.com/helipod-sh/helipod"
