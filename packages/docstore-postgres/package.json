{
  "name": "@helipod/docstore-postgres",
  "version": "0.1.3",
  "type": "module",
  "license": "FSL-1.1-Apache-2.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./test-support/embedded-pg": {
      "types": "./test-support/embedded-pg.ts",
      "default": "./test-support/embedded-pg.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --testTimeout=60000 --hookTimeout=60000",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@helipod/docstore": "workspace:*",
    "@helipod/id-codec": "workspace:*",
    "@helipod/index-key-codec": "workspace:*",
    "@helipod/values": "workspace:*",
    "pg": "^8.13.1",
    "pg-cursor": "^2.21.0"
  },
  "devDependencies": {
    "@helipod/test": "workspace:*",
    "@helipod/executor": "workspace:*",
    "@electric-sql/pglite": "^0.2.17",
    "embedded-postgres": "16.14.0-beta.17",
    "@types/pg": "^8.11.10",
    "@types/pg-cursor": "^2.7.2",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helipod-sh/helipod.git",
    "directory": "packages/docstore-postgres"
  },
  "homepage": "https://github.com/helipod-sh/helipod"
}
