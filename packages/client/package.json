{
  "name": "@stackbase/client",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./outbox-fs": {
      "types": "./dist/outbox-fs.d.ts",
      "default": "./dist/outbox-fs.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "dependencies": {
    "@stackbase/sync": "workspace:*",
    "@stackbase/values": "workspace:*"
  },
  "devDependencies": {
    "@stackbase/docstore-sqlite": "workspace:*",
    "@stackbase/executor": "workspace:*",
    "@stackbase/id-codec": "workspace:*",
    "@stackbase/query-engine": "workspace:*",
    "@stackbase/runtime-embedded": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@types/node": "catalog:",
    "@types/react": "^18.3.18",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
