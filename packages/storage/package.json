{
  "name": "@helipod/storage",
  "version": "0.0.0",
  "type": "module",
  "license": "FSL-1.1-Apache-2.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@helipod/blobstore": "workspace:*",
    "@helipod/component": "workspace:*",
    "@helipod/errors": "workspace:*",
    "@helipod/executor": "workspace:*",
    "@helipod/id-codec": "workspace:*",
    "@helipod/values": "workspace:*"
  },
  "devDependencies": {
    "@helipod/docstore-sqlite": "workspace:*",
    "@helipod/runtime-embedded": "workspace:*",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
