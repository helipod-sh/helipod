{
  "name": "@helipod/runtime-cloudflare",
  "version": "0.1.2",
  "type": "module",
  "license": "FSL-1.1-Apache-2.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:workers": "vitest run --config vitest.workers.config.ts",
    "test:e2e": "vitest run --config vitest.workers.config.ts test-workers/*-e2e.test.ts",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@helipod/admin": "workspace:*",
    "@helipod/blobstore": "workspace:*",
    "@helipod/cli": "workspace:*",
    "@helipod/component": "workspace:*",
    "@helipod/docstore": "workspace:*",
    "@helipod/docstore-d1": "workspace:*",
    "@helipod/docstore-do-sqlite": "workspace:*",
    "@helipod/docstore-sqlite": "workspace:*",
    "@helipod/executor": "workspace:*",
    "@helipod/runtime-embedded": "workspace:*",
    "@helipod/storage": "workspace:*",
    "@helipod/sync": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.5.40",
    "@cloudflare/workers-types": "^4.20241127.0",
    "@helipod/blobstore-r2": "workspace:*",
    "@helipod/docstore": "workspace:*",
    "@helipod/id-codec": "workspace:*",
    "@helipod/index-key-codec": "workspace:*",
    "@helipod/values": "workspace:*",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helipod-sh/helipod.git",
    "directory": "packages/runtime-cloudflare"
  },
  "homepage": "https://github.com/helipod-sh/helipod"
}
