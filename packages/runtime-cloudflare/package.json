{
  "name": "@stackbase/runtime-cloudflare",
  "version": "0.0.0",
  "type": "module",
  "license": "FSL-1.1-Apache-2.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:workers": "vitest run --config vitest.workers.config.ts",
    "test:e2e": "vitest run --config vitest.workers.config.ts test-workers/*-e2e.test.ts",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@stackbase/admin": "workspace:*",
    "@stackbase/blobstore": "workspace:*",
    "@stackbase/cli": "workspace:*",
    "@stackbase/component": "workspace:*",
    "@stackbase/docstore": "workspace:*",
    "@stackbase/docstore-d1": "workspace:*",
    "@stackbase/docstore-do-sqlite": "workspace:*",
    "@stackbase/docstore-sqlite": "workspace:*",
    "@stackbase/executor": "workspace:*",
    "@stackbase/runtime-embedded": "workspace:*",
    "@stackbase/storage": "workspace:*",
    "@stackbase/sync": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.5.40",
    "@cloudflare/workers-types": "^4.20241127.0",
    "@stackbase/blobstore-r2": "workspace:*",
    "@stackbase/docstore": "workspace:*",
    "@stackbase/id-codec": "workspace:*",
    "@stackbase/index-key-codec": "workspace:*",
    "@stackbase/values": "workspace:*",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
