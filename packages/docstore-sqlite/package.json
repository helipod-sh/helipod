{
  "name": "@helipod/docstore-sqlite",
  "version": "0.1.4",
  "type": "module",
  "license": "FSL-1.1-Apache-2.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --testTimeout=60000 --hookTimeout=60000",
    "test:bun": "bun run test/bun-smoke.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@helipod/docstore": "workspace:*",
    "@helipod/id-codec": "workspace:*",
    "@helipod/values": "workspace:*"
  },
  "devDependencies": {
    "@helipod/index-key-codec": "workspace:*",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helipod-sh/helipod.git",
    "directory": "packages/docstore-sqlite"
  },
  "homepage": "https://github.com/helipod-sh/helipod"
}
