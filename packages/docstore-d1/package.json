{
  "name": "@helipod/docstore-d1",
  "version": "0.1.3",
  "type": "module",
  "license": "FSL-1.1-Apache-2.0",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --exclude 'test/*-e2e.test.ts' --testTimeout=60000 --hookTimeout=60000",
    "test:e2e": "vitest run test/*-e2e.test.ts --testTimeout=60000 --hookTimeout=60000",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@helipod/values": "workspace:*"
  },
  "devDependencies": {
    "better-sqlite3": "^11.8.0",
    "@types/better-sqlite3": "^7.6.12",
    "miniflare": "^3.20241205.0",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helipod-sh/helipod.git",
    "directory": "packages/docstore-d1"
  },
  "homepage": "https://github.com/helipod-sh/helipod"
}
