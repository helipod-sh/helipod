{
  "name": "@stackbase/cli",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "bin": {
    "stackbase": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@stackbase/admin": "workspace:*",
    "@stackbase/codegen": "workspace:*",
    "@stackbase/component": "workspace:*",
    "@stackbase/docstore": "workspace:*",
    "@stackbase/docstore-postgres": "workspace:*",
    "@stackbase/docstore-sqlite": "workspace:*",
    "@stackbase/errors": "workspace:*",
    "@stackbase/executor": "workspace:*",
    "@stackbase/id-codec": "workspace:*",
    "@stackbase/query-engine": "workspace:*",
    "@stackbase/runtime-embedded": "workspace:*",
    "@stackbase/sync": "workspace:*",
    "@stackbase/values": "workspace:*",
    "esbuild": "^0.27.0",
    "ws": "^8.18.0",
    "@stackbase/dashboard": "workspace:*"
  },
  "devDependencies": {
    "@stackbase/client": "workspace:*",
    "@stackbase/scheduler": "workspace:*",
    "@stackbase/workflow": "workspace:*",
    "@types/node": "catalog:",
    "@types/ws": "^8.5.13",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
