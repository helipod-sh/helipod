{
  "name": "@stackbase/cli",
  "version": "0.0.0",
  "type": "module",
  "license": "FSL-1.1-Apache-2.0",
  "bin": {
    "stackbase": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./http-handler": {
      "types": "./dist/http-handler.d.ts",
      "default": "./dist/http-handler.js"
    },
    "./project": {
      "types": "./dist/project.d.ts",
      "default": "./dist/project.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --exclude 'test/*-e2e.test.ts'",
    "test:e2e": "vitest run test/*-e2e.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@stackbase/admin": "workspace:*",
    "@stackbase/blobstore": "workspace:*",
    "@stackbase/blobstore-fs": "workspace:*",
    "@stackbase/blobstore-s3": "workspace:*",
    "@stackbase/codegen": "workspace:*",
    "@stackbase/component": "workspace:*",
    "@stackbase/docstore": "workspace:*",
    "@stackbase/docstore-postgres": "workspace:*",
    "@stackbase/docstore-sqlite": "workspace:*",
    "@stackbase/errors": "workspace:*",
    "@stackbase/executor": "workspace:*",
    "@stackbase/id-codec": "workspace:*",
    "@stackbase/objectstore": "workspace:*",
    "@stackbase/objectstore-fs": "workspace:*",
    "@stackbase/objectstore-s3": "workspace:*",
    "@stackbase/query-engine": "workspace:*",
    "@stackbase/receipts": "workspace:*",
    "@stackbase/runtime-embedded": "workspace:*",
    "@stackbase/storage": "workspace:*",
    "@stackbase/sync": "workspace:*",
    "@stackbase/values": "workspace:*",
    "esbuild": "^0.27.0",
    "ws": "^8.18.0",
    "@stackbase/dashboard": "workspace:*"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@levischuck/tiny-cbor": "0.2.11",
    "@simplewebauthn/server": "13.3.2",
    "@stackbase/auth": "workspace:*",
    "@stackbase/client": "workspace:*",
    "@stackbase/fleet": "workspace:*",
    "@stackbase/notifications": "workspace:*",
    "@stackbase/objectstore-substrate": "workspace:*",
    "@stackbase/scheduler": "workspace:*",
    "@stackbase/triggers": "workspace:*",
    "@stackbase/workflow": "workspace:*",
    "@types/node": "catalog:",
    "@types/ws": "^8.5.13",
    "fake-indexeddb": "^6.0.0",
    "jose": "6.2.3",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
