{
  "name": "@helipod/cli",
  "version": "0.1.0",
  "type": "module",
  "license": "FSL-1.1-Apache-2.0",
  "bin": {
    "helipod": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./http-handler": {
      "types": "./dist/http-handler.d.ts",
      "default": "./dist/http-handler.js"
    },
    "./project": {
      "types": "./dist/project.d.ts",
      "default": "./dist/project.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --exclude 'test/*-e2e.test.ts'",
    "test:e2e": "vitest run test/*-e2e.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@helipod/admin": "workspace:*",
    "@helipod/blobstore": "workspace:*",
    "@helipod/blobstore-fs": "workspace:*",
    "@helipod/blobstore-s3": "workspace:*",
    "@helipod/codegen": "workspace:*",
    "@helipod/component": "workspace:*",
    "@helipod/deploy": "workspace:*",
    "@helipod/docstore": "workspace:*",
    "@helipod/docstore-postgres": "workspace:*",
    "@helipod/docstore-sqlite": "workspace:*",
    "@helipod/errors": "workspace:*",
    "@helipod/executor": "workspace:*",
    "@helipod/id-codec": "workspace:*",
    "@helipod/objectstore": "workspace:*",
    "@helipod/objectstore-fs": "workspace:*",
    "@helipod/objectstore-s3": "workspace:*",
    "@helipod/query-engine": "workspace:*",
    "@helipod/receipts": "workspace:*",
    "@helipod/runtime-embedded": "workspace:*",
    "@helipod/storage": "workspace:*",
    "@helipod/sync": "workspace:*",
    "@helipod/values": "workspace:*",
    "esbuild": "^0.27.0",
    "ws": "^8.18.0",
    "@helipod/dashboard": "workspace:*"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@levischuck/tiny-cbor": "0.2.11",
    "@simplewebauthn/server": "13.3.2",
    "@helipod/auth": "workspace:*",
    "@helipod/client": "workspace:*",
    "@helipod/fleet": "workspace:*",
    "@helipod/notifications": "workspace:*",
    "@helipod/objectstore-substrate": "workspace:*",
    "@helipod/scheduler": "workspace:*",
    "@helipod/triggers": "workspace:*",
    "@helipod/workflow": "workspace:*",
    "@types/node": "catalog:",
    "@types/ws": "^8.5.13",
    "fake-indexeddb": "^6.0.0",
    "jose": "6.2.3",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helipod-sh/helipod.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/helipod-sh/helipod"
}
