{
  "name": "@helipod/vite",
  "version": "0.1.4",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "test": "vitest run --exclude 'test/*-e2e.test.ts' --testTimeout=60000 --hookTimeout=60000",
    "test:e2e": "vitest run test/*-e2e.test.ts --testTimeout=60000 --hookTimeout=60000",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "vite": ">=5.0.0",
    "@helipod/cli": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@helipod/cli": {
      "optional": true
    }
  },
  "devDependencies": {
    "@helipod/cli": "workspace:*",
    "@helipod/client": "workspace:*",
    "@helipod/executor": "workspace:*",
    "@helipod/id-codec": "workspace:*",
    "@helipod/values": "workspace:*",
    "@types/node": "catalog:",
    "@types/ws": "^8.5.13",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "^6.0.7",
    "vitest": "catalog:",
    "ws": "^8.18.0"
  },
  "files": [
    "dist"
  ],
  "license": "FSL-1.1-Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helipod-sh/helipod.git",
    "directory": "packages/vite"
  },
  "homepage": "https://github.com/helipod-sh/helipod"
}
