{
  "name": "@stackbase/vite",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "test": "vitest run --exclude 'test/*-e2e.test.ts'",
    "test:e2e": "vitest run test/*-e2e.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": { "vite": ">=5.0.0", "@stackbase/cli": "workspace:*" },
  "peerDependenciesMeta": {
    "@stackbase/cli": {
      "optional": true
    }
  },
  "devDependencies": {
    "@stackbase/cli": "workspace:*",
    "@stackbase/client": "workspace:*",
    "@stackbase/executor": "workspace:*",
    "@stackbase/id-codec": "workspace:*",
    "@stackbase/values": "workspace:*",
    "@types/node": "catalog:",
    "@types/ws": "^8.5.13",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "^6.0.7",
    "vitest": "catalog:",
    "ws": "^8.18.0"
  }
}
