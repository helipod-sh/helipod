{
  "name": "@helipod/example-auth-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --testTimeout=60000 --hookTimeout=60000",
    "web:build": "bun build web/main.tsx --outfile web/main.js",
    "dev": "bun ../../packages/cli/dist/bin.js dev --web web --port 3211"
  },
  "dependencies": {
    "@helipod/auth": "workspace:*",
    "@helipod/component": "workspace:*",
    "@helipod/executor": "workspace:*",
    "@helipod/scheduler": "workspace:*",
    "@helipod/values": "workspace:*",
    "@helipod/workflow": "workspace:*"
  },
  "devDependencies": {
    "@helipod/admin": "workspace:*",
    "@helipod/cli": "workspace:*",
    "@helipod/client": "workspace:*",
    "@helipod/docstore-sqlite": "workspace:*",
    "@helipod/id-codec": "workspace:*",
    "@helipod/runtime-embedded": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
